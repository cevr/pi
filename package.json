{
  "name": "@cvr/pi",
  "version": "0.0.1",
  "private": true,
  "description": "Custom pi coding-agent extensions and core utilities",
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/core/*",
      "packages/extensions/*"
    ],
    "catalog": {
      "@mariozechner/pi-coding-agent": "^0.58.0",
      "@mariozechner/pi-tui": "^0.58.0"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.js"
    }
  },
  "scripts": {
    "sync:pi-extensions": "node ./scripts/sync-pi-extensions-manifest.mjs",
    "build": "node ./scripts/sync-pi-extensions-manifest.mjs && tsdown && node ./scripts/sync-pi-extensions-manifest.mjs",
    "lint": "oxlint --format=stylish --report-unused-disable-directives",
    "lint:fix": "oxlint --format=stylish --fix --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "bun run --filter '@cvr/pi-mermaid' typecheck && bun run --filter '@cvr/pi-command-palette' typecheck && bun run --filter '@cvr/pi-editor' typecheck",
    "test": "bun test",
    "gate": "concurrently -n type,lint,fmt,test,build -c blue,yellow,magenta,green,cyan \"bun run typecheck\" \"bun run lint\" \"bun run format:check\" \"bun run test\" \"bun run build\"",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "cheerio": "^1.0.0",
    "diff": "^8.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "effect": "4.0.0-beta.31",
    "effect-bun-test": "^0.2.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.56.0",
    "@mariozechner/pi-coding-agent": ">=0.56.0",
    "@mariozechner/pi-tui": ">=0.56.0",
    "@sinclair/typebox": ">=0.34.0"
  },
  "pi": {
    "extensions": [
      "./dist/extensions/audit.js",
      "./dist/extensions/auto-skills.js",
      "./dist/extensions/bash.js",
      "./dist/extensions/command-palette.js",
      "./dist/extensions/counsel.js",
      "./dist/extensions/create-file.js",
      "./dist/extensions/edit-file.js",
      "./dist/extensions/editor.js",
      "./dist/extensions/finder.js",
      "./dist/extensions/glob.js",
      "./dist/extensions/grep.js",
      "./dist/extensions/handoff.js",
      "./dist/extensions/librarian.js",
      "./dist/extensions/ls.js",
      "./dist/extensions/mentions.js",
      "./dist/extensions/mermaid.js",
      "./dist/extensions/oracle.js",
      "./dist/extensions/plan-mode.js",
      "./dist/extensions/read.js",
      "./dist/extensions/read-session.js",
      "./dist/extensions/review-loop.js",
      "./dist/extensions/search-sessions.js",
      "./dist/extensions/session-closer.js",
      "./dist/extensions/session-name.js",
      "./dist/extensions/skill.js",
      "./dist/extensions/skill-capture.js",
      "./dist/extensions/skill-mentions.js",
      "./dist/extensions/system-prompt.js",
      "./dist/extensions/task.js",
      "./dist/extensions/tool-harness.js",
      "./dist/extensions/undo-edit.js",
      "./dist/extensions/web-search.js"
    ]
  }
}
