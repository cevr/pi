{
  "name": "@cvr/pi",
  "version": "0.0.1",
  "private": true,
  "description": "Custom pi coding-agent extensions and core utilities",
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/core/*",
      "packages/extensions/*"
    ],
    "catalog": {
      "@mariozechner/pi-coding-agent": "^0.58.0",
      "@mariozechner/pi-tui": "^0.58.0"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint --type-aware --format=stylish --type-check --report-unused-disable-directives",
    "lint:fix": "oxlint --type-aware --format=stylish --type-check --fix --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "bun run --filter '@cvr/pi-mermaid' typecheck && bun run --filter '@cvr/pi-command-palette' typecheck && bun run --filter '@cvr/pi-editor' typecheck",
    "test": "vitest run",
    "check": "bun run format && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "cheerio": "^1.0.0",
    "diff": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^3.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.56.0",
    "@mariozechner/pi-coding-agent": ">=0.56.0",
    "@mariozechner/pi-tui": ">=0.56.0",
    "@sinclair/typebox": ">=0.34.0"
  }
}
